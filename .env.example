# RakshaGIS Environment Configuration
# Copy to .env and edit with your values
# Required fields marked with [REQUIRED]

# ── Core Configuration ──────────────────────────────────────────────────────
# Persistent data directory on host (Docker volumes mount here)
DATA_DIR=/data/rakshagis

# Django settings module (development or production)
DJANGO_SETTINGS_MODULE=config.settings.production

# ── Django Security ────────────────────────────────────────────────────────
# REQUIRED: Long random string for session/CSRF signing
# Generate: python -c "import secrets; print(secrets.token_hex(50))"
SECRET_KEY=change-this-to-a-long-random-string-of-at-least-50-chars

# Enable debug mode (NEVER True in production)
DEBUG=False

# Comma-separated allowed hostnames/IPs
ALLOWED_HOSTS=localhost,127.0.0.1,your-server-ip,your-domain.com

# CORS origins (for separate frontend domain)
CORS_ALLOWED_ORIGINS=

# ── Database (PostgreSQL + PostGIS) ────────────────────────────────────────
# REQUIRED
DB_NAME=rakshagis
DB_USER=raksha
DB_PASSWORD=change-this-to-a-strong-password
DB_HOST=db
DB_PORT=5432

# ── Redis & Celery ────────────────────────────────────────────────────────
# Redis connection URLs
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1

# ── OnlyOffice Document Server ────────────────────────────────────────────
# REQUIRED: JWT secret for OnlyOffice ↔ Django communication
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
ONLYOFFICE_JWT_SECRET=change-this-to-a-random-secret

# Internal URL OnlyOffice uses to reach Django (for document callbacks)
ONLYOFFICE_INTERNAL_BASE_URL=http://nginx

# ── Local AI / LLM Backends ────────────────────────────────────────────────
# Primary Ollama URLs (test all, first accessible one is used)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_HOST_URL=http://host.docker.internal:11434
OLLAMA_DOCKER_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2

# Alternative AI backends (LocalAI, llama.cpp, AnythingLLM)
LOCALAI_BASE_URL=http://localhost:8080
LLAMACPP_BASE_URL=http://localhost:8000
ANYTHINGLLM_BASE_URL=http://localhost:3001

# ── 3D Terrain / Elevation ───────────────────────────────────────────────
# Cesium ION token for online terrain (optional)
CESIUM_ION_TOKEN=

# Local terrain tile server URL (set to /terrain-tiles when using terrain profile)
TERRAIN_TILE_URL=

# ── Backup & Recovery ────────────────────────────────────────────────────
# Encryption key for backups (AES-128 Fernet)
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Leave blank to auto-generate in BACKUP_DIR/.backup_key
BACKUP_ENCRYPTION_KEY=

# Backup directory and retention
BACKUP_DIR=/data/rakshagis/backups
BACKUP_RETENTION_DAYS=30

# ── Media & Static Files ──────────────────────────────────────────────────
MEDIA_ROOT=/data/rakshagis/media

# ── HTTPS / TLS (Production) ───────────────────────────────────────────────
# Uncomment for production with Let's Encrypt
# SECURE_SSL_REDIRECT=True
# SECURE_HSTS_SECONDS=31536000
# SESSION_COOKIE_SECURE=True
# CSRF_COOKIE_SECURE=True

# ── Logging (Optional) ────────────────────────────────────────────────────
# LOG_FILE=/data/rakshagis/logs/django.log
# LOG_LEVEL=INFO

# ── GIS / GDAL (Advanced) ────────────────────────────────────────────────
# Usually auto-detected, uncomment if not found:
# GDAL_LIBRARY_PATH=/usr/lib/x86_64-linux-gnu/libgdal.so
# GEOS_LIBRARY_PATH=/usr/lib/x86_64-linux-gnu/libgeos_c.so.1

# ── GPU Support ──────────────────────────────────────────────────────────
# Enable NVIDIA GPU for AI (false = CPU only)
AI_BACKEND_GPU=false

# Enabled AI backend profiles (space-separated)
# Options: docker-ollama, docker-ollama-gpu, localai, localai-gpu,
#          llamacpp, llamacpp-gpu, anythingllm, anythingllm-gpu,
#          osm, terrain, monitoring, https
AI_BACKENDS=docker-ollama

# ── Data directory ─────────────────────────────────────────────────
# HOST path where all persistent data is stored (PostgreSQL, media, GIS files).
# Docker Compose mounts this to /data inside every app container.
# setup.sh fills this in automatically.
DATA_DIR=/data/rakshagis

# ── Django ──────────────────────────────────────────────────────────
DEBUG=False
SECRET_KEY=change-this-to-a-long-random-string
ALLOWED_HOSTS=your-server-ip,your-domain.com

# ── Database (PostgreSQL + PostGIS) ────────────────────────────────
DB_NAME=rakshagis
DB_USER=raksha
DB_PASSWORD=change-this-password
DB_HOST=localhost
DB_PORT=5432            # 5432 on production, 5439 on this WSL2 host

# ── Redis / Celery ──────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1

# ── Local AI (Ollama) ───────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3    # or mistral, gemma2, deepseek-r1

# ── Django settings module ──────────────────────────────────────────
# development  → config.settings.development
# production   → config.settings.production
DJANGO_SETTINGS_MODULE=config.settings.production

# ── Production only ─────────────────────────────────────────────────
# CORS_ALLOWED_ORIGINS=https://your-domain.com
# SECURE_SSL_REDIRECT=True
# STATIC_ROOT=/opt/rakshagis/RakshaGIS/staticfiles
# MEDIA_ROOT=/opt/rakshagis/RakshaGIS/media
# LOG_FILE=/opt/rakshagis/logs/django.log
#
# If GDAL is not auto-detected:
# GDAL_LIBRARY_PATH=/usr/lib/x86_64-linux-gnu/libgdal.so
# GEOS_LIBRARY_PATH=/usr/lib/x86_64-linux-gnu/libgeos_c.so.1
